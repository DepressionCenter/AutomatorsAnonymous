<script>
// --- ADVANCED ROBUST AUDIO ENGINE ---
function playAndEnvelopeAudio() {
    const audio = document.getElementById('aa-soundtrack');
    
    // Strict internal volume tracking bypasses JS floating point read errors
    let currentVol = 0.40; // Start at 40% volume
    audio.volume = currentVol;
    
    // Play the audio
    audio.play().catch(e => console.warn("Audio blocked by browser."));

    // Step 1: Fade 40% -> 15% over 4.5 seconds (45 steps of 100ms)
    const targetVol1 = 0.15;
    const steps1 = 45;
    const fadeDownAmount1 = (currentVol - targetVol1) / steps1;
    
    let fade1 = setInterval(() => {
        currentVol -= fadeDownAmount1;
        if (currentVol <= targetVol1) {
            audio.volume = targetVol1;
            clearInterval(fade1);
        } else {
            audio.volume = currentVol;
        }
    }, 100);

    // Step 2: 7-Second fade to 0% starting at 7.5 seconds (after animations complete)
    setTimeout(() => {
        let currentVol2 = 0.15;
        const targetVol2 = 0.0;
        const steps2 = 120; // 120 steps of 100ms = 12 seconds
        const fadeDownAmount2 = currentVol2 / steps2;
        
        let fade2 = setInterval(() => {
            currentVol2 -= fadeDownAmount2;
            if (currentVol2 <= 0) {
                audio.volume = 0;
                audio.pause();
                clearInterval(fade2);
            } else {
                audio.volume = currentVol2;
            }
        }, 100);
    }, 7500);
}

// --- BOOT SEQUENCE LOGIC ---
function startBootSequence() {
    const splash = document.getElementById('aa-splash');
    if(splash.classList.contains('booting')) return; 
    
    // 1. Lock in the booting state & fire the custom audio engine
    splash.classList.add('booting');
    playAndEnvelopeAudio();

    // 2. The 15 Keywords finish. Fade background, reveal UI, and shrink logo IMMEDIATELY at 4.8s.
    setTimeout(() => {
        splash.classList.add('reveal-ui');
        splash.classList.add('contract'); 
        document.querySelector('.aa-main-content').classList.add('active');
    }, 4800); 

    // 3. Clean up the DOM to restore full interactivity once all animations complete
    setTimeout(() => {
        splash.style.display = 'none';
    }, 6500);
}

// Check Accessibility Preferences
if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.getElementById('aa-splash').style.display = 'none';
    document.querySelector('.aa-main-content').style.opacity = '1';
    document.querySelector('.aa-main-content').style.pointerEvents = 'auto';
}

// --- ONE-WAY DIRECTORY DECLASSIFICATION ---
