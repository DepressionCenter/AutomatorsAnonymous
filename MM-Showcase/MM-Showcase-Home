        { name: "Shelley Boa", email: "EMAIL_HERE", role: "Program Manager", dept: "Internal Medicine / Pulmonology & Critical Care", linkedin: "https://www.linkedin.com/in/shelleyboa/", website: "", github: "https://github.com/blondilox-ai" },
        { name: "Beth Plotts", email: "EMAIL_HERE", role: "Manager of Departmental Information Delivery", dept: "HITS EDIS Analytics, Michigan Medicine", linkedin: "https://www.linkedin.com/in/elizabeth-plotts-46a5a349", website: "", github: "" },
        { name: "David Clark", email: "EMAIL_HERE", role: "Business Systems Analyst", dept: "Anesthesiology, Michigan Medicine", linkedin: "https://www.linkedin.com/in/davidclark23", website: "", github: "" },
        { name: "Frans Antonissen", email: "EMAIL_HERE", role: "Software Developer", dept: "Radiology, Michigan Medicine", linkedin: "", website: "https://mcommunity.umich.edu/person/antoniss", github: "" },
        { name: "TJ Petras", email: "EMAIL_HERE", role: "Business Systems Analyst", dept: "Facilities Administration, Michigan Medicine", linkedin: "https://www.linkedin.com/in/tjpetras", website: "", github: "" },
