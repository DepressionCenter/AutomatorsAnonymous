            } catch(e) { imgUrl = item.Preview; }

            // Target Top 3 for the explosive entrance, the rest just smoothly appear
            const isTopThree = idx < 3;
            const animationClass = isTopThree ? 'explode' : 'appear';
            
            // Stagger the first 3 by 0.5s each. The rest appear simultaneously slightly after the fireworks end.
            const staggerDelay = isTopThree ? idx * 0.5 : 1.5;

            html += `
                <div class="aa-project-card ${animationClass}" style="--stagger-delay: ${staggerDelay}s;">
                    <div class="aa-img-frame">
                        <img src="${imgUrl}" onerror="this.src='https://via.placeholder.com/600x400/03080f/00E5FF?text=PROJECT+UPLINK'">
