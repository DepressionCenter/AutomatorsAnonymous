                        <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 25px;">${item.Summary || ''}</p>
                        <div style="display:flex; gap:10px;">
                            ${item.Website ? `<a href="${item.Website}" target="_blank" class="aa-project-btn">LAUNCH</a>` : ''}
                            ${item.Demo ? `<a href="${item.Demo}" target="_blank" class="aa-project-btn">DEMO</a>` : ''}
                            ${item.Code ? `<a href="${item.Code}" target="_blank" class="aa-project-btn">SOURCE</a>` : ''}
                        </div>
                    </div>
                </div>
            `;
        });
        document.getElementById('aa-project-grid').innerHTML = html;
    }

    // --- PERSONNEL LOGIC ---
    const team = [
        { name: "Gabriel Mongefranco", email: "EMAIL_HERE", role: "Sr. Mobile Data Architect", dept: "Mobile Technologies Core, Eisenberg Family Depression Center", linkedin: "", website: "https://gabriel.mongefranco.com", github: "https://github.com/gabrielmongefranco" },
