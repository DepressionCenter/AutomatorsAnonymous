    function renderTeam() {
        let html = '';
        team.forEach(m => {
            const photo = (m.email && m.email !== "EMAIL_HERE") 
                ? `${siteUrl}/_layouts/15/userphoto.aspx?size=L&accountname=${m.email}`
                : `data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%237A8B9E'><path d='M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z'/></svg>`;

            html += `
                <div class="aa-team-mini-card">
                    <img src="${photo}" class="aa-mini-avatar" alt="${m.name}">
                    <div style="font-weight:bold; color:#fff; font-size: 0.95rem;">${m.name}</div>
                    <div style="color:var(--umich-maize); font-size:0.75rem; margin: 6px 0; font-weight:bold;">${m.role}</div>
                    <div style="color:var(--text-muted); font-size:0.65rem; line-height: 1.4;">${m.dept}</div>
                    <div class="aa-social-links">
                        ${m.github ? `<a href="${m.github}" target="_blank">GITHUB</a>` : ''}
                        ${m.linkedin ? `<a href="${m.linkedin}" target="_blank">LINKEDIN</a>` : ''}
                        ${m.website ? `<a href="${m.website}" target="_blank">WEBSITE</a>` : ''}
                    </div>
                </div>
            `;
        });
        document.getElementById('aa-directory-content').innerHTML = html;
    }

    // Fire data requests immediately so the DOM is ready before the user clicks Start
    fetchProjects();
    renderTeam();
})();
</script>
</body>
</html>
