(function() {
    const siteUrl = window._spPageContextInfo ? _spPageContextInfo.webAbsoluteUrl : window.location.origin + window.location.pathname.substring(0, window.location.pathname.indexOf('/SitePages'));
    
    // --- PROJECTS LOGIC ---
    const listName = 'Projects';
    const restUrl = `${siteUrl}/_api/web/lists/getbytitle('${listName}')/items?$filter=Featured eq 1&$select=ID,Title,Summary,Preview,Demo,Website,Code,Docs&$orderby=Modified desc`;

    async function fetchProjects() {
        try {
            const response = await fetch(restUrl, { headers: { 'Accept': 'application/json;odata=nometadata' } });
            if (!response.ok) throw new Error('Data fetch failed');
            const data = await response.json();
            renderProjects(data.value);
        } catch (e) { 
            console.error(e);
            document.getElementById('aa-loading').innerHTML = 'Offline. Verify connection.';
        }
    }

    function renderProjects(items) {
        document.getElementById('aa-loading').style.display = 'none';
        let html = '';
